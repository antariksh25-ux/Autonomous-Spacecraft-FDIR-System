FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/FDIR

# System deps (kept minimal)
RUN pip install --no-cache-dir --upgrade pip

COPY FDIR/requirements.txt /app/FDIR/requirements.txt
RUN pip install --no-cache-dir -r /app/FDIR/requirements.txt

COPY FDIR/ /app/FDIR/

EXPOSE 8001

CMD ["gunicorn", "-c", "backend/gunicorn_conf.py", "backend.api:app"]
